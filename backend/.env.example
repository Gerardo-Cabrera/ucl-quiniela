# Database
# PostgreSQL nativo del host (setup único del rol/BD: ver docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://quiniela:quiniela_pass@localhost:5432/ucl_quiniela

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API-Football: dos formas de acceder a la MISMA API (elige según tu cuenta).
#
# Opción A — vía RapidAPI (key de ~50 chars, por defecto):
#   https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=your_rapidapi_key_here
API_FOOTBALL_PROVIDER=rapidapi
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
#
# Opción B — acceso DIRECTO api-sports.io (key de 32 chars):
#   https://dashboard.api-football.com/  → "My Access"
#   API_FOOTBALL_PROVIDER=apisports
#   API_FOOTBALL_HOST=v3.football.api-sports.io
#
# (API_FOOTBALL_PROVIDER=auto deduce el proveedor por el host.)

# UCL League ID en API-Football = 2
UCL_LEAGUE_ID=2
# Temporada (año de inicio: 2026 = 2026/27). Con 0, el sistema la identifica
# automáticamente vía API (la temporada marcada como 'current').
UCL_SEASON=2026

# Sync de fixtures adaptativo (opcional; defaults en config.py):
#   ~1 min mientras hay partido en juego, y respaldo cada N min el resto.
#SYNC_FIXTURES_MINUTES=1
#SYNC_FIXTURES_IDLE_MINUTES=30

# Zona horaria (IANA) para agrupar partidos por jornada/día en la vista de MVPs.
#TOURNAMENT_TZ=Europe/Madrid

# Los pronósticos de una jornada cierran estos minutos antes de su primer partido.
# El interruptor admin de prórroga (/predictions/override) reabre hasta ese partido.
#PREDICTION_LEAD_MINUTES=60

# App
APP_ENV=development
# Varios orígenes: separar por comas (ej: http://localhost:5173,https://miapp.com)
CORS_ORIGINS=http://localhost:5173

# Rate limiting (opcional; valores por defecto en config.py).
#RATE_LIMIT_ENABLED=true
#RATE_LIMIT_DEFAULT=60/minute
# Límite reforzado en /auth/* (login y registro), anti fuerza bruta:
#RATE_LIMIT_AUTH=10/minute
# Límite en el sync admin (/matches/sync); protege la cuota de API-Football:
#RATE_LIMIT_SYNC=10/hour
